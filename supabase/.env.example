# Supabase local dev — OAuth secrets
# Copy this file to supabase/.env and fill in your values.
# supabase/.env is .gitignored and must never be committed.
#
# How to get these values:
#   1. Go to https://console.cloud.google.com
#   2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorised redirect URIs — add BOTH:
#        http://127.0.0.1:54321/auth/v1/callback   ← local Supabase
#        https://<your-project>.supabase.co/auth/v1/callback  ← cloud (add later)
#   5. Copy the Client ID and Client Secret below.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Cloud DB password (from project creation — used by `supabase db push`)
SUPABASE_DB_PASSWORD=
