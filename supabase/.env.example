# Supabase local dev - OAuth secrets
# Copy this file to supabase/.env and fill in your values.
# supabase/.env is .gitignored and must never be committed.
#
# How to get these values:
#   1. Go to https://console.cloud.google.com
#   2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorised redirect URIs - add BOTH:
#        http://127.0.0.1:54321/auth/v1/callback   ← local Supabase
#        https://<your-project>.supabase.co/auth/v1/callback  ← cloud (add later)
#   5. Copy the Client ID and Client Secret below.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Manual Supabase operations (`./scripts/supabase-ops.sh`)
#
# Supabase CLI login/profile or an externally supplied SUPABASE_ACCESS_TOKEN
# owns API authentication. These values only scope project/database targets and
# the staging synthetic-persona seed.
STAGING_SUPABASE_PROJECT_REF=
STAGING_SUPABASE_DB_PASSWORD=
STAGING_SUPABASE_URL=
STAGING_SUPABASE_SERVICE_ROLE_KEY=
STAGING_DEMO_EMAIL=
STAGING_DEMO_PASSWORD=
STAGING_E2E_SMOKE_EMAIL=
STAGING_E2E_SMOKE_PASSWORD=

PROD_SUPABASE_PROJECT_REF=
PROD_SUPABASE_DB_PASSWORD=
