# Supabase local-dev defaults for RLS regression tests (pnpm test:rls).
# Copy this file to `.env.test` (gitignored) and fill the keys from
# `supabase status -o env` after `supabase start`.
#
# Do not commit JWTs here. Even local Supabase demo JWTs are flagged by
# GitGuardian and should live only in `.env.test`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RLS_TEST_PASSWORD=test-password-rls
