# Supabase local-dev defaults for RLS regression tests (pnpm test:rls).
# Copy this file to `.env.test` (gitignored) and fill the keys from
# `supabase status -o env` after `supabase start`.
#
# Do not commit JWTs here. Even local Supabase demo JWTs are flagged by
# GitGuardian and should live only in `.env.test`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL for psql, check-security-advisors.sh, and RLS specs.
# Default matches `supabase start`; override only if your local port differs.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
RLS_TEST_PASSWORD=test-password-rls

# Local manual personas created by `pnpm seed:local`.
# Default password == email (e.g. admin@portfelik.test / admin@portfelik.test).
# Set these only to override the defaults.
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=
LOCAL_USER_EMAIL=
LOCAL_USER_PASSWORD=
