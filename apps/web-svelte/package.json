{
	"name": "web-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint src/",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"seed:local": "SEED_TARGET=local node ./scripts/seed-personas.mjs",
		"seed:staging": "node ./scripts/seed-staging.mjs",
		"test:e2e": "playwright test",
		"test:e2e:install": "playwright install chromium",
		"test:e2e:install:deps": "playwright install --with-deps chromium",
		"postinstall": "playwright install chromium",
		"test:unit": "vitest run --config vitest.unit.config.ts",
		"test:components": "vitest run --config vitest.components.config.ts",
		"test:rls": "vitest run",
		"test:rls:watch": "vitest"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^9.39.4",
		"@inlang/paraglide-js": "^2.16.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^25.6.2",
		"canvas-confetti": "^1.9.4",
		"eslint": "^9.39.4",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^15.15.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.7",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.0",
		"@supabase/supabase-js": "^2.104.0",
		"@tanstack/svelte-query": "^6.1.18",
		"@tanstack/svelte-query-devtools": "^6.1.18",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"lucide-svelte": "^1.0.1",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.5.0"
	}
}
