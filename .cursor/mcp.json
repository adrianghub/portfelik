{
  "mcpServers": {
    "supabase-prod": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref=emqzcygfwcvbmhxhfkcc",
        "--features=storage,branching,development,functions,debugging,account,database,docs"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "supabase-staging": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=nveyzxxnyccpnesebvuw",
        "--features=storage,development,functions,debugging,database,docs"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "svelte": {
      "type": "http",
      "url": "https://mcp.svelte.dev/mcp"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "obscura": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@obscuraai/mcp-server"]
    }
  }
}
