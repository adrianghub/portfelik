# SvelteKit — local Supabase environment
# Copy to .env.local (gitignored). Values below are the fixed local dev defaults
# printed by `supabase start`. They are safe to share — local only, not production.
#
# After running `supabase start`, confirm these match the output.

# Local Supabase API
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=<paste anon key from `supabase start` output>

# For the Supabase CLI type generator (supabase gen types typescript)
# Used in package.json scripts, not at runtime.
SUPABASE_PROJECT_ID=portfelik
